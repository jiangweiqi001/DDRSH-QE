  ibrav       = 2
  celldm(1)   = 7.605
  nat         = 2
  ntyp        = 2
  ecutwfc     = 80.0
  ecutrho     = 320.0
  occupations = 'fixed'
  nbnd        = 12
/
&electrons
  conv_thr    = 1.0d-12
  mixing_beta = 0.7
/
