&control
  calculation = 'scf'
  prefix      = 'naclfg'
  outdir      = './out_fg'
  pseudo_dir  = '../../../../pseudos'
  verbosity   = 'high'
  tstress     = .false.
  tprnfor     = .false.
/
&system
  ibrav       = 2
  celldm(1)   = 10.573   ! a = 5.595 A (experimental)
  nat         = 2
  ntyp        = 2
  ecutwfc     = 50.0
  ecutrho     = 200.0
  occupations = 'fixed'
  nbnd        = 16
  input_dft        = 'hse'
  lmodelhf         = .true.
  aexx             = 0.3953
  bexx             = 0.4319
  hfscreen         = 0.5938
  exxdiv_treatment = 'gygi-baldereschi'
  nqx1 = 6, nqx2 = 6, nqx3 = 6
/
&electrons
  conv_thr    = 1.0d-8
  mixing_beta = 0.7
/
ATOMIC_SPECIES
Na    22.990  Na_ONCV_PBE-1.2.upf
Cl    35.453  Cl_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
Na    0.0   0.0   0.0
Cl    0.5   0.5   0.5
K_POINTS automatic
6 6 6 0 0 0
