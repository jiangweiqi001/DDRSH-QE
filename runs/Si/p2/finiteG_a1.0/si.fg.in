&control
  calculation = 'scf'
  prefix      = 'sifg'
  outdir      = './out_fg'
  pseudo_dir  = '../../../../pseudos'
  verbosity   = 'high'
  tstress     = .false.
  tprnfor     = .false.
/
&system
  ibrav       = 2
  celldm(1)   = 10.263   ! a = 5.431 A (experimental)
  nat         = 2
  ntyp        = 1
  ecutwfc     = 60.0
  ecutrho     = 240.0
  occupations = 'fixed'
  nbnd        = 12
  input_dft        = 'hse'
  lmodelhf         = .true.
  aexx             = 0.0913
  bexx             = 0.2923
  hfscreen         = 0.6571
  exxdiv_treatment = 'gygi-baldereschi'
  nqx1 = 6, nqx2 = 6, nqx3 = 6
/
&electrons
  conv_thr    = 1.0d-8
  mixing_beta = 0.7
/
ATOMIC_SPECIES
Si    28.085  Si_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
Si    0.0   0.0   0.0
Si   0.25  0.25  0.25
K_POINTS automatic
6 6 6 0 0 0
