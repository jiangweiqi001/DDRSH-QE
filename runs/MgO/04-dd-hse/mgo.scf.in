&control
  calculation = 'scf'
  prefix      = 'mgo'
  outdir      = './out'
  pseudo_dir  = '../../../pseudos'
  verbosity   = 'high'
/
&system
  ibrav            = 2
  celldm(1)        = 7.9104   ! a = 4.186 A (experimental)
  nat              = 2
  ntyp             = 2
  ecutwfc          = 80.0
  ecutrho          = 320.0
  occupations      = 'fixed'
  nbnd             = 16
  input_dft        = 'hse'
! Approximate dielectric-dependent screened hybrid (NOT exact DD-RSH-CAM).
! QE HSE removes Fock in the long range; DD-RSH-CAM keeps screened Fock there.
! alpha = 1 / epsilon_inf from literature 2.81 -> 0.355872; replace after 02-eps.
  exx_fraction        = 0.310833
! QE screening_parameter is in bohr^-1. Literature DD-RSH-CAM MgO mu = 0.63 bohr^-1.
  screening_parameter = 0.63
  exxdiv_treatment    = 'gygi-baldereschi'
  nqx1 = 3
  nqx2 = 3
  nqx3 = 3
/
&electrons
  conv_thr    = 1.0d-8
  mixing_beta = 0.7
/
ATOMIC_SPECIES
Mg  24.305  Mg_ONCV_PBE-1.2.upf
O   15.999  O_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
Mg  0.0  0.0  0.0
O   0.5  0.5  0.5
K_POINTS automatic
6 6 6 0 0 0
