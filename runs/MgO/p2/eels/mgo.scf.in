&control
  calculation = 'scf'
  prefix      = 'mgo'
  outdir      = './out'
  pseudo_dir  = '../../../../pseudos'
  verbosity   = 'high'
/
&system
  ibrav       = 2
  celldm(1)   = 7.9104
  nat         = 2
  ntyp        = 2
  ecutwfc     = 80.0
  ecutrho     = 320.0
  occupations = 'fixed'
  nbnd        = 16
/
&electrons
  conv_thr    = 1.0d-12
  mixing_beta = 0.7
/
