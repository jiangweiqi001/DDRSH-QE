&control
  calculation = 'scf'
  prefix      = 'fit4148'
  outdir      = './out_fit4148'
  pseudo_dir  = '../../../../pseudos'
  verbosity   = 'high'
  tstress     = .false.
  tprnfor     = .false.
/
&system
  ibrav            = 2
  celldm(1)        = 7.8387   ! a = 4.148 A (paper lattice)
  nat              = 2
  ntyp             = 2
  ecutwfc          = 80.0
  ecutrho          = 320.0
  occupations      = 'fixed'
  nbnd             = 16
  input_dft        = 'hse'
  lmodelhf         = .true.
  aexx             = 0.3234
  bexx             = 1.0
  hfscreen         = 0.7257
  exxdiv_treatment = 'gygi-baldereschi'
  nqx1 = 6, nqx2 = 6, nqx3 = 6
/
&electrons
  conv_thr    = 1.0d-8
  mixing_beta = 0.7
/
ATOMIC_SPECIES
Mg  24.305  Mg_ONCV_PBE-1.2.upf
O   15.999  O_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
Mg  0.0  0.0  0.0
O   0.5  0.5  0.5
K_POINTS automatic
6 6 6 0 0 0
