&control
  calculation = 'scf'
  prefix      = 'mgo'
  outdir      = './out_pbe0_model'
  pseudo_dir  = '../../../pseudos'
  verbosity   = 'high'
  tstress     = .false.
  tprnfor     = .false.
/
&system
  ibrav       = 2
  celldm(1)   = 7.9104
  nat         = 2
  ntyp        = 2
  ecutwfc     = 40.0
  ecutrho     = 160.0
  occupations = 'fixed'
  nbnd        = 12
  input_dft   = 'hse'
  lmodelhf    = .true.
  aexx        = 0.25
  bexx        = 0.25
  hfscreen    = 0.106
  nqx1 = 2, nqx2 = 2, nqx3 = 2
/
&electrons
  conv_thr    = 1.0d-9
  mixing_beta = 0.7
/
ATOMIC_SPECIES
Mg  24.305  Mg_ONCV_PBE-1.2.upf
O   15.999  O_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
Mg  0.0  0.0  0.0
O   0.5  0.5  0.5
K_POINTS automatic
2 2 2 0 0 0
