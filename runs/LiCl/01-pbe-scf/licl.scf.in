&control
  calculation = 'scf'
  prefix      = 'licl'
  outdir      = './out'
  pseudo_dir  = '../../../pseudos'
  verbosity   = 'high'
  tprnfor     = .true.
  tstress     = .true.
/
&system
  ibrav       = 2
  celldm(1)   = 9.649   ! a = 5.106 A (experimental, licl.toml)
  nat         = 2
  ntyp        = 2
  ecutwfc     = 50.0
  ecutrho     = 200.0
  occupations = 'fixed'
  nbnd        = 12
/
&electrons
  conv_thr    = 1.0d-10
  mixing_beta = 0.7
/
ATOMIC_SPECIES
Li   6.941  Li_ONCV_PBE-1.2.upf
Cl  35.453  Cl_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
Li  0.0  0.0  0.0
Cl  0.5  0.5  0.5
K_POINTS automatic
8 8 8 0 0 0
